# Copy to `.env` and fill in. Never commit `.env`.

# GitHub PAT (classic or fine-grained) with these scopes:
#   - manage_billing:copilot   (read Copilot billing / seats)
#   - read:org                 (list teams + team-scoped metrics)
#   - repo                     (PR detail across private repos for the Users / Quality tabs)
#   - Plan: Read (fine-grained) OR manage_billing:enterprise (classic)
#                                (enhanced-billing API for per-user AI-credit rollups)
GITHUB_TOKEN=

# GitHub org login (default: Juniper-SSN)
GITHUB_ORG=Juniper-SSN

# GitHub enterprise slug (default: juniper-net).
# Used as a fallback when org-scope endpoints 404 (org metrics, billing usage).
# Set to empty string to disable the fallback.
GITHUB_ENTERPRISE=juniper-net

# Per-seat monthly cost in USD (used for ROI math)
SEAT_COST_USD=39.0

# Minutes saved per accepted suggestion (tunable benchmark, 0.5 is a common baseline)
MINUTES_SAVED_PER_ACCEPTANCE=0.5

# Inactivity threshold for "stale" seats (days)
STALE_SEAT_DAYS=30

# Daily snapshot time (UTC, "HH:MM")
SNAPSHOT_TIME_UTC=02:00

# ---------------------------------------------------------------------------
# Data persistence (docker-compose)
# ---------------------------------------------------------------------------
# Host directory bind-mounted to /data, holding copilot.db. It already
# survives `docker compose down`, `down -v`, and image rebuilds. Point it
# OUTSIDE the repo to decouple the DB from the project folder's lifecycle
# (so re-cloning / moving / deleting the repo can't take the data with it).
# Default: ./data
# DATA_DIR=~/copilot-usage-data

# Docker host ports
# BACKEND_PORT=8000
# FRONTEND_PORT=8080

# CORS allowlist for the frontend (JSON list). For docker-compose this is set in compose.yml.
# CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# ---------------------------------------------------------------------------
# PR ingestion (powers the Users + Quality tabs)
# ---------------------------------------------------------------------------
# Set to false to skip PR ingestion entirely (faster snapshots).
PR_INGEST_ENABLED=true
# How far back to walk repos for PR activity.
PR_LOOKBACK_DAYS=120
# Cap on repos scanned per snapshot (alphabetical order).
PR_MAX_REPOS=300
# Parallel PR-detail fetches.
PR_CONCURRENCY=4
# Whether to include forked repos.
PR_INCLUDE_FORKS=false
# Whether to include archived repos.
PR_INCLUDE_ARCHIVED=false

# ---------------------------------------------------------------------------
# Seed / preview mode (no PAT required)
# ---------------------------------------------------------------------------
# Set to true after running `python -m scripts.seed_test_data` so the boot
# snapshot, daily cron, and POST /api/snapshot/run won't overwrite your
# synthetic data. Leave unset / false in production.
# SEED_MODE=false
